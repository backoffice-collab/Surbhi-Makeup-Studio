# Copy to .env.local and fill in. .env.local is gitignored — never commit real keys.

# Google Gemini API key for the AI Beauty Advisor's vision analysis.
# Get one at https://aistudio.google.com/apikey
# If this is unset, the advisor falls back to on-device analysis and no
# photo ever leaves the user's browser.
GEMINI_API_KEY=
