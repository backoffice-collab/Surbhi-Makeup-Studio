# Copy to .env.local and fill in. .env.local is gitignored — never commit real keys.

# Google Gemini API key for the AI Beauty Advisor's vision analysis.
# Get one at https://aistudio.google.com/apikey
# If this is unset, the advisor falls back to on-device analysis and no
# photo ever leaves the user's browser.
GEMINI_API_KEY=

# --- Supabase (contact / booking enquiries) --------------------------------
# From your Supabase project: Settings → API.
# SUPABASE_URL is the "Project URL" (e.g. https://xxxx.supabase.co).
# SUPABASE_PUBLISHABLE_KEY is the "publishable" key (sb_publishable_...). It is
# public by design and safe to expose; security comes from the insert-only Row
# Level Security policy, NOT from hiding this key. Do NOT use the secret key
# (sb_secret_...) here. If unset, the contact form still works via WhatsApp; it
# just won't save a copy to the database.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
